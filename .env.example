# Application
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
API_PREFIX=v1

# Database
DATABASE_URL=postgresql://flowpilot:flowpilot_dev@localhost:5432/flowpilot?schema=public

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookies
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Mail (Mailpit for local)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM="FlowPilot <noreply@flowpilot.local>"

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# File uploads (local stub for M0)
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads
MAX_FILE_SIZE_MB=10
