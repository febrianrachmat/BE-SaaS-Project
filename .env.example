# Application
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
API_PREFIX=v1

# Database
DATABASE_URL=postgresql://flowpilot:flowpilot_dev@localhost:5432/flowpilot?schema=public

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_REMEMBER_EXPIRES_IN=30d

# Cookies
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Mail (Mailpit locally; real SMTP in production)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="FlowPilot <noreply@flowpilot.local>"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/v1/auth/google/callback

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# File uploads
# local (default) or s3 (AWS S3 / Cloudflare R2 / MinIO)
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads
MAX_FILE_SIZE_MB=10

# S3 / R2 (required when STORAGE_DRIVER=s3)
# S3_BUCKET=flowpilot
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=auto
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_FORCE_PATH_STYLE=true
